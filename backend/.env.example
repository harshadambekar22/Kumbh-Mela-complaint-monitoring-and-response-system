PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/kumbh-complaints
AI_SERVICE_URL=http://127.0.0.1:8001
# Web dashboard origin(s) for CORS (comma-separated). Add your deployed frontend URL after Render deploy.
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,https://your-frontend.onrender.com
JWT_SECRET=change-me
JWT_EXPIRES_IN=12h
SOCIAL_SYNC_ENABLED=true
SOCIAL_SYNC_INTERVAL_MS=60000
SOCIAL_KEYWORDS=nashik,kumbh,kumbhmela,kumbh mela
X_BEARER_TOKEN=
X_QUERY=(nashik OR kumbh OR kumbhmela OR "kumbh mela") lang:en -is:retweet
X_MAX_RESULTS=25
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_IDS=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=
